# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id_here
DISCORD_CHANNEL_ID=your_discord_channel_id_here

# Optional: Limit to a specific guild for faster slash command registration during development
# DISCORD_GUILD_ID=your_guild_id_here

# Anthropic API (optional - for AI-powered Korean summaries)
# If not set, bot will use raw content excerpts instead
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Timezone (default: Asia/Seoul)
TZ=Asia/Seoul

# News schedule (default: every hour on the hour)
# NEWS_SCHEDULE=0 * * * *
